{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "cleanUrls": true,
    "routes": [
        {
            "src": "/index.html",
            "status": 200
        },
        {
            "src": "/(.*\\.[a-z]+)$",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html",
            "status": 200
        }
    ],
    "env": {
        "SKIP_ENV_VALIDATION": "true"
    }
}