{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/browser",
    "cleanUrls": true,
    "trailingSlash": false,
    "routes": [
        {
            "src": "^/.*\\.(js|css|svg|png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot)$",
            "dest": "/$0",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "^/(?!.*\\.).*$",
            "dest": "/index.html"
        }
    ]
}